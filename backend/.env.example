# Environment Configuration
NODE_ENV=development
PORT=5000

# Database URL (PostgreSQL)
# For local development, use: postgresql://username:password@localhost:5432/pvc_portfolio
# For production, use your cloud database URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/pvc_portfolio?schema=public"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-this
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email Configuration (Titan / custom SMTP)
# Titan (Namecheap) usually uses:
# SMTP_HOST=smtp.titan.email
# SMTP_PORT=587
# SMTP_SECURE=false
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=contact@pranijheightsindia.com
SMTP_PASS=your-smtp-password
EMAIL_FROM="Pranijheightsindia <contact@pranijheightsindia.com>"

# Notification Recipients (who receives website inquiry alerts)
# Comma-separated list. Falls back to ADMIN_EMAIL if empty.
NOTIFICATION_EMAILS=contact@pranijheightsindia.com
ADMIN_EMAIL=contact@pranijheightsindia.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload (Cloudinary - optional)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# File Upload Directory (local VPS storage)
# All uploaded images, PDFs, and files are stored on the VPS disk
UPLOAD_DIR=/var/www/pranijheightsindia/backend/uploads

# Admin Default Password (only used during initial seed - use a strong password)
ADMIN_DEFAULT_PASSWORD=change-this-strong-password-123!
